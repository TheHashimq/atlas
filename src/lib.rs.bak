mod engine;
mod runtime;
mod features;

use std::cell::RefCell;
use std::rc::Rc;
use std::sync::Arc;

use wasm_bindgen::prelude::*;
use wasm_bindgen::JsCast;
use wasm_bindgen_futures::spawn_local;
use web_sys::{window, HtmlCanvasElement};

use engine::gpu::{device::GpuDevice, surface::GpuSurface};
use engine::math::{camera::Camera, transform::Transform};
use engine::render::{mesh::Mesh, renderer::Renderer, material::Material};
use engine::time::clock::Clock;

use runtime::scene::{Scene, PointLight};
use runtime::input::{OrbitCamera, attach_orbit_listeners};

#[wasm_bindgen(start)]
pub fn start() {
    console_error_panic_hook::set_once();
    console_log::init_with_level(log::Level::Info).expect("logger");

    spawn_local(async move {

        let window   = window().expect("no window");
        let document = window.document().expect("no document");

        let canvas = document
            .get_element_by_id("gfx")
            .expect("canvas not found")
            .dyn_into::<HtmlCanvasElement>()
            .expect("not a canvas");

        // ---- GPU ----
        let instance = wgpu::Instance::default();
        let mut surface = GpuSurface::new(&instance, &canvas);
        let gpu = GpuDevice::new(&instance, &surface.surface).await;

// ddReplace the on_uncaptured_error call with:
 
        gpu.device.on_uncaptured_error(Arc::new(|error: wgpu::Error| {
            log::error!("WebGPU device error: {:?}", error);
        }));
        let dpr    = window.device_pixel_ratio();
        let width  = (canvas.client_width()  as f64 * dpr) as u32;
        let height = (canvas.client_height() as f64 * dpr) as u32;
        canvas.set_width(width);
        canvas.set_height(height);
        surface.resize(&gpu.adapter, &gpu.device, width, height);

        let surface_format = surface.config.format;

        // ---- Renderer ----
        let renderer = Rc::new(RefCell::new(Renderer::new(
            &gpu.device, surface_format, width, height,
        )));

        // ---- Orbit Camera ----
        let orbit = Rc::new(RefCell::new(OrbitCamera::new(8.0)));
        let listeners = attach_orbit_listeners(&canvas, orbit.clone());
        // listeners must be kept alive for the duration of the app
        let _listeners = Rc::new(listeners);

        let camera = Rc::new(RefCell::new(Camera {
            position : glam::Vec3::new(0.0, 3.0, 8.0),
            target   : glam::Vec3::ZERO,
            up       : glam::Vec3::Y,
            aspect   : width as f32 / height as f32,
            fov_y    : 60f32.to_radians(),
            near     : 0.1,
            far      : 100.0,
        }));

        // ---- Scene ----
        let mut scene = Scene::new(camera.clone());

        // Ground plane
        let ground_mesh = Rc::new(Mesh::ground_plane(&gpu.device, 20.0, 40));
        let ground_t    = Rc::new(RefCell::new(Transform::identity()));
        scene.add_object(ground_mesh, ground_t, Material::ground());

        // Pyramid 1 — blue dielectric
        let pyramid = Rc::new(Mesh::pyramid(&gpu.device));
        let t1 = Rc::new(RefCell::new(Transform::identity()));
        {
            let mut t = t1.borrow_mut();
            t.translation = glam::Vec3::new(-2.0, 0.0, 0.0);
            t.scale       = glam::Vec3::splat(0.8);
        }
        scene.add_object(pyramid.clone(), t1.clone(), Material::default_blue());

        // Pyramid 2 — metallic gold
        let t2 = Rc::new(RefCell::new(Transform::identity()));
        {
            let mut t = t2.borrow_mut();
            t.translation = glam::Vec3::new(2.0, 0.0, 0.0);
            t.scale       = glam::Vec3::splat(0.8);
        }
        scene.add_object(pyramid.clone(), t2.clone(), Material::metal());

        // Light sphere (visual) — rendered as emissive
        let sphere_mesh = Rc::new(Mesh::sphere(&gpu.device));
        let light_t     = Rc::new(RefCell::new(Transform::identity()));
        light_t.borrow_mut().scale = glam::Vec3::splat(0.18);
        scene.add_object(sphere_mesh, light_t.clone(), Material::light_source());

        // Register as a scene point light so the shader sees it
        scene.add_point_light(
            light_t.clone(),
            PointLight { color: [1.0, 0.92, 0.6], intensity: 18.0 },
        );

        // Cool blue fill light — static, top left
        let fill_t = Rc::new(RefCell::new(Transform::identity()));
        fill_t.borrow_mut().translation = glam::Vec3::new(-6.0, 5.0, -2.0);
        scene.add_point_light(
            fill_t,
            PointLight { color: [0.3, 0.5, 1.0], intensity: 5.0 },
        );

        let scene   = Rc::new(RefCell::new(scene));
        let surface = Rc::new(RefCell::new(surface));
        let camera  = camera.clone();

        // ---- Clock ----
        let clock = Rc::new(RefCell::new(Clock::new()));

        // ---- RAF ----
        let raf: Rc<RefCell<Option<Closure<dyn FnMut()>>>> = Rc::new(RefCell::new(None));
        let raf_clone       = raf.clone();
        let window_for_loop = window.clone();

        *raf_clone.borrow_mut() = Some(Closure::wrap(Box::new(move || {

            // Keep listeners alive inside RAF closure
            let _keep_alive = &_listeners;

            let result = std::panic::catch_unwind(std::panic::AssertUnwindSafe(|| {

                clock.borrow_mut().tick();
                let delta = clock.borrow().delta_seconds();
                let time  = js_sys::Date::now() as f32 * 0.001;
                let radius = 5.5f32;

                // ---- Resize check ----
                {
                    let dpr        = window_for_loop.device_pixel_ratio();
                    let new_width  = (js_sys::global()
                        .dyn_ref::<web_sys::Window>()
                        .map(|w| w.inner_width().ok()
                            .and_then(|v| v.as_f64())
                            .unwrap_or(800.0))
                        .unwrap_or(800.0) * dpr) as u32;
                    // Use canvas client size for accurate resize detection
                    let canvas_el = window_for_loop
                        .document().unwrap()
                        .get_element_by_id("gfx").unwrap()
                        .dyn_into::<HtmlCanvasElement>().unwrap();
                    let new_w = (canvas_el.client_width()  as f64 * dpr) as u32;
                    let new_h = (canvas_el.client_height() as f64 * dpr) as u32;

                    let mut surf = surface.borrow_mut();
                    if new_w != surf.config.width || new_h != surf.config.height {
                        canvas_el.set_width(new_w);
                        canvas_el.set_height(new_h);
                        surf.resize(&gpu.adapter, &gpu.device, new_w, new_h);
                        renderer.borrow_mut().resize(&gpu.device, new_w, new_h);
                        camera.borrow_mut().aspect = new_w as f32 / new_h as f32;
                        log::info!("Resized to {}x{}", new_w, new_h);
                    }
                }

                // ---- Update orbit camera ----
                {
                    let mut cam = camera.borrow_mut();
                    orbit.borrow().update_camera(&mut cam);
                }

                // ---- Update scene objects ----
                {
                    let scene_ref = scene.borrow();

                    // Rotate pyramid 1 (index 1, ground is 0)
                    scene_ref.objects[1].transform.borrow_mut().rotation *=
                        glam::Quat::from_rotation_y(delta * 1.2);

                    // Rotate pyramid 2
                    scene_ref.objects[2].transform.borrow_mut().rotation *=
                        glam::Quat::from_rotation_x(delta * 0.9);

                    // Orbit light sphere — figure-8 path
                    let lx = time.cos() * radius;
                    let lz = time.sin() * radius;
                    let ly = 2.5 + (time * 0.7).sin() * 1.5;
                    scene_ref.objects[3].transform.borrow_mut().translation =
                        glam::Vec3::new(lx, ly, lz);
                }

                // ---- Render ----
                let mut surface_ref = surface.borrow_mut();
                let frame = match surface_ref.surface.get_current_texture() {
                    Ok(f)  => f,
                    Err(e) => {
                        log::warn!("get_current_texture: {:?}", e);
                        return;
                    },
                };

                let view = frame.texture.create_view(&wgpu::TextureViewDescriptor::default());

                renderer.borrow_mut().render_scene(
                    &gpu.device,
                    &gpu.queue,
                    &view,
                    &scene.borrow(),
                );

                frame.present();

            }));

            if let Err(e) = result {
                log::error!("RAF panic: {:?}", e);
            }

            window_for_loop
                .request_animation_frame(
                    raf.borrow().as_ref().unwrap().as_ref().unchecked_ref(),
                )
                .unwrap();

        }) as Box<dyn FnMut()>));

        window
            .request_animation_frame(
                raf_clone.borrow().as_ref().unwrap().as_ref().unchecked_ref(),
            )
            .unwrap();
    });
}
